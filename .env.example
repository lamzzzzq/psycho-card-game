# Supabase 配置（PVP 房间同步 + 课堂数据收集）
# 在 Supabase Dashboard → Project Settings → API 取得
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# 注意：anon key 是公开可用的（前端直连）。当前 RLS 关闭，课堂场景够用；
# 正式部署给学校前建议开 RLS + 服务端校验。建表见 supabase/migrations/0001_game_records.sql
